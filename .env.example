GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
GEMINI_MODEL=gemini-2.5-flash

# Deployed demo URLs:
DEPLOYED_FRONTEND_URL=https://voltstream-project-95144.web.app
DEPLOYED_BACKEND_URL=https://voltstream-backend-335699237868.us-central1.run.app

# Local default uses SQLite. Use these for Cloud SQL MySQL.
# DATABASE_ENGINE=mysql
# MYSQL_DATABASE=voltstream
# MYSQL_USER=voltstream_user
# MYSQL_PASSWORD=your_mysql_password

# Local testing through Cloud SQL public IP:
# MYSQL_HOST=your_cloud_sql_public_ip
# MYSQL_PORT=3306

# Cloud Run connection. Use this instead of MYSQL_HOST in deployed backend:
# CLOUD_SQL_CONNECTION_NAME=your-project-id:us-central1:voltstream-mysql
# MYSQL_UNIX_SOCKET=/cloudsql/your-project-id:us-central1:voltstream-mysql
